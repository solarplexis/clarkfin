rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function currentUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function currentUserExists() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function currentUserData() {
      return currentUserDoc().data;
    }

    function isAdmin() {
      return currentUserExists() && currentUserData().role == "ADMIN";
    }

    function isOrgAdmin() {
      return currentUserExists() && currentUserData().role == "ORG_ADMIN";
    }

    function isStudent() {
      return currentUserExists() && currentUserData().role == "STUDENT";
    }

    function sameOrg(orgId) {
      return currentUserExists() && currentUserData().organizationId == orgId;
    }

    function enrolledInSemester(semesterId) {
      return currentUserExists()
        && exists(
          /databases/$(database)/documents/student_enrollments/$(request.auth.uid + "_" + semesterId)
        );
    }

    function ownsUser(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function validStudentScopedWrite(orgId, semesterId, userId) {
      return isStudent()
        && ownsUser(userId)
        && sameOrg(orgId)
        && enrolledInSemester(semesterId);
    }

    match /users/{uid} {
      allow read: if isAdmin()
        || ownsUser(uid)
        || (isOrgAdmin() && sameOrg(resource.data.organizationId));

      allow create: if isAdmin()
        || (ownsUser(uid)
          && request.resource.data.role == "STUDENT"
          && request.resource.data.organizationId is string
          && (!request.resource.data.keys().hasAny(["activeSemesterId"])
            || request.resource.data.activeSemesterId is string));

      allow update: if isAdmin()
        || (ownsUser(uid)
          && request.resource.data.role == resource.data.role
          && request.resource.data.organizationId == resource.data.organizationId
          && request.resource.data.activeSemesterId is string);

      allow delete: if isAdmin();
    }

    match /organizations/{orgId} {
      allow read: if isAdmin() || (isOrgAdmin() && sameOrg(orgId));
      allow write: if isAdmin();
    }

    match /semesters/{semesterId} {
      allow read: if isAdmin()
        || (signedIn() && sameOrg(resource.data.orgId));
      allow write: if isAdmin()
        || (isOrgAdmin() && sameOrg(request.resource.data.orgId));
    }

    match /students/{studentId} {
      allow read: if isAdmin()
        || (isOrgAdmin() && sameOrg(resource.data.organizationId))
        || (isStudent() && resource.data.authUserId == request.auth.uid);

      allow create, update: if isAdmin()
        || (isOrgAdmin() && sameOrg(request.resource.data.organizationId));

      allow delete: if isAdmin()
        || (isOrgAdmin() && sameOrg(resource.data.organizationId));
    }

    match /student_invites/{inviteId} {
      allow read: if isAdmin()
        || (isOrgAdmin() && sameOrg(resource.data.organizationId));

      allow create, update: if isAdmin()
        || (isOrgAdmin() && sameOrg(request.resource.data.organizationId));

      allow delete: if isAdmin();
    }

    match /student_enrollments/{enrollmentId} {
      allow read: if isAdmin()
        || (isOrgAdmin() && sameOrg(resource.data.organizationId))
        || (isStudent() && ownsUser(resource.data.userId));

      allow create, update: if isAdmin()
        || (isOrgAdmin() && sameOrg(request.resource.data.organizationId));

      allow delete: if isAdmin();
    }

    match /activity_logs/{logId} {
      allow read: if isAdmin()
        || (isOrgAdmin() && sameOrg(resource.data.organizationId))
        || (isStudent() && ownsUser(resource.data.userId));

      allow create: if isAdmin()
        || validStudentScopedWrite(
          request.resource.data.organizationId,
          request.resource.data.semesterId,
          request.resource.data.userId
        )
        || (isOrgAdmin() && sameOrg(request.resource.data.organizationId));

      allow update, delete: if isAdmin();
    }

    match /budget_drafts/{draftId} {
      allow read: if isAdmin()
        || (isOrgAdmin() && sameOrg(resource.data.organizationId))
        || (isStudent() && ownsUser(resource.data.userId));

      allow create, update: if isAdmin()
        || validStudentScopedWrite(
          request.resource.data.organizationId,
          request.resource.data.semesterId,
          request.resource.data.userId
        );

      allow delete: if isAdmin() || (isStudent() && ownsUser(resource.data.userId));
    }

    match /debt_scenarios/{scenarioId} {
      allow read: if isAdmin()
        || (isOrgAdmin() && sameOrg(resource.data.organizationId))
        || (isStudent() && ownsUser(resource.data.userId));

      allow create, update: if isAdmin()
        || validStudentScopedWrite(
          request.resource.data.organizationId,
          request.resource.data.semesterId,
          request.resource.data.userId
        );

      allow delete: if isAdmin() || (isStudent() && ownsUser(resource.data.userId));
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
