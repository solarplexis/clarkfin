rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: get the caller's user document
    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isMemberOf(orgId) {
      return isSignedIn() && userDoc().organizationId == orgId;
    }

    function isAdminOf(orgId) {
      return isSignedIn() && userDoc().organizationId == orgId && userDoc().role == 'ADMIN';
    }

    // ── Organizations ──────────────────────────────────────────────
    match /organizations/{orgId} {
      allow read: if isMemberOf(orgId);
      allow write: if false; // managed server-side only
    }

    // ── Semesters ──────────────────────────────────────────────────
    match /semesters/{semesterId} {
      allow read: if isSignedIn() && userDoc().semesterId == semesterId;
      allow write: if false;
    }

    // ── Users ──────────────────────────────────────────────────────
    match /users/{uid} {
      // Users can read/write their own document
      allow read, write: if isSignedIn() && request.auth.uid == uid;
      // Admins in the same org can read any student document
      allow read: if isAdminOf(resource.data.organizationId);
    }

    // ── Activity Logs ──────────────────────────────────────────────
    match /activity_logs/{logId} {
      // Student can write their own logs
      allow create: if isSignedIn()
        && request.auth.uid == request.resource.data.studentId
        && userDoc().organizationId == request.resource.data.orgId;
      // Student can read their own logs
      allow read: if isSignedIn() && request.auth.uid == resource.data.studentId;
      // Admin can read all logs in their org
      allow read: if isAdminOf(resource.data.orgId);
      allow update, delete: if false;
    }

    // ── Invite Codes ───────────────────────────────────────────────
    match /inviteCodes/{code} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ── Budget Entries ─────────────────────────────────────────────
    match /budget_entries/{entryId} {
      allow read, write: if isSignedIn() && request.auth.uid == resource.data.userId;
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.userId;
    }

    // ── Debt Simulations ───────────────────────────────────────────
    match /debt_simulations/{simId} {
      allow read, write: if isSignedIn() && request.auth.uid == resource.data.userId;
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.userId;
    }
  }
}
